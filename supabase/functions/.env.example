# Local secrets for `supabase functions serve` (DO NOT COMMIT).
# Copy to `supabase/functions/.env` and fill in. The production values are pushed
# separately with `supabase secrets set` (see commands below).
#
# IMPORTANT: ASC_PRIVATE_KEY must be the ENTIRE .p8 on ONE line, with the real
# newlines replaced by literal "\n" sequences. Generate it like this from the
# project root:
#
#   awk 'NF {sub(/\r/,""); printf "%s\\n", $0}' AuthKey_RABPNXA8U4.p8
#
# Paste the output between the quotes below.

ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGT...one...line...\n-----END PRIVATE KEY-----\n"
ASC_ISSUER_ID="00000000-0000-0000-0000-000000000000"
ASC_KEY_ID="RABPNXA8U4"

# Optional: lock CORS to your real site(s), comma-separated. Defaults to "*".
ALLOWED_ORIGINS="http://localhost:3000,https://your-site.example"

# Optional: app id used when a request omits `appId`. Digits only.
ASC_DEFAULT_APP_ID="1181860241"
