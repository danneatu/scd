# App Store Connect API credentials
# Get these from https://appstoreconnect.apple.com/access/api

# The Issuer ID shown at the top of the "Keys" tab (a UUID).
ASC_ISSUER_ID=your-issuer-id-uuid

# The Key ID of the API key you generated (e.g. ABCD1234EF).
# Recommended role: "Customer Support" — the least-privilege role that can read
# reviews. It cannot delete the app, change pricing, or access financials.
ASC_KEY_ID=your-key-id

# Path to the downloaded private key (.p8 file).
# You can only download this ONCE from App Store Connect, so keep it safe.
ASC_PRIVATE_KEY_PATH=./AuthKey_YOURKEYID.p8

# Alternatively, paste the private key contents directly (use \n for newlines).
# If set, this takes precedence over ASC_PRIVATE_KEY_PATH.
# ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# The numeric Apple ID of the app to analyze.
APP_ID=1181860241

# Port for the local web server.
PORT=3000

# --- Daily sync schedule (node-cron) ---
# Cron expression for the automatic daily review pull. Default: 06:00 every day.
SYNC_CRON=0 6 * * *

# --- Optional: Downloads via Sales Reports ---
# Requires a SEPARATE App Store Connect API key with the "Sales" role
# (read-only; it cannot delete the app or change pricing). The Issuer ID is
# account-wide, so ASC_ISSUER_ID above is reused unless you set SALES_ISSUER_ID.
# SALES_KEY_ID=XXXXXXXXXX
# SALES_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
# Your numeric Vendor Number (App Store Connect → Payments and Financial Reports).
# SALES_VENDOR_NUMBER=8XXXXXXX
# Earliest year to include for the all-time total (auto-detected from the app's
# release date when omitted).
# DOWNLOADS_START_YEAR=2017

# --- Optional: AI summarizer for the monthly insights report ---
# If left unset, the app uses a free, local heuristic (no data leaves your machine).
# Set these to get richer, themed pain-point / praise summaries with the
# "refine" skill (translates German, sharper titles/descriptions/actions).
#
# FREE providers (recommended) — pick ONE:
#
#   Groq (fast, generous free tier):
#     LLM_PROVIDER=groq
#     LLM_API_KEY=gsk_...           # https://console.groq.com/keys
#     # LLM_MODEL=llama-3.3-70b-versatile   (default)
#
#   Google Gemini (free tier):
#     LLM_PROVIDER=google
#     LLM_API_KEY=AIza...           # https://aistudio.google.com/apikey
#     # LLM_MODEL=gemini-2.0-flash          (default)
#
#   OpenRouter (free models — note the ":free" suffix):
#     LLM_PROVIDER=openrouter
#     LLM_API_KEY=sk-or-...         # https://openrouter.ai/keys
#     # LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free   (default)
#
#   Mistral (free tier):
#     LLM_PROVIDER=mistral
#     LLM_API_KEY=...               # https://console.mistral.ai/api-keys
#
#   Cerebras (free):
#     LLM_PROVIDER=cerebras
#     LLM_API_KEY=csk-...           # https://cloud.cerebras.ai
#
#   Ollama (100% local, no key, no data leaves your machine):
#     LLM_PROVIDER=ollama
#     # LLM_MODEL=llama3.1          (run: `ollama pull llama3.1` first)
#
# PAID providers:
#     LLM_PROVIDER=openai           # LLM_API_KEY=sk-...     LLM_MODEL=gpt-4o-mini
#     LLM_PROVIDER=anthropic        # LLM_API_KEY=sk-ant-... LLM_MODEL=claude-3-5-sonnet-latest
#
# Advanced: point any OpenAI-compatible host at a custom base URL:
#     LLM_BASE_URL=https://your-host/v1

# Language for the AI-written analysis (summary, pain-point titles/descriptions,
# suggested actions). Default: English. Examples: de, fr, es, it, pt, nl.
# Only affects the LLM "refine" output; the local heuristic stays English.
# REPORT_LANGUAGE=de

# --- Optional: Daily email notification for NEW written reviews ---
# When configured, the daily sync emails you whenever new written reviews arrive.
# Set the recipient, then pick ONE delivery backend below.
#
#   NOTIFY_TO=you@example.com
#   # Optional sender shown in the "From" field:
#   # NOTIFY_FROM="App Reviews <notifications@yourdomain.com>"
#
# Backend A — Resend HTTP API (easiest; no SMTP server, just an API key):
#   RESEND_API_KEY=re_...            # https://resend.com/api-keys
#   # With a free Resend account you can send from onboarding@resend.dev:
#   # NOTIFY_FROM="App Reviews <onboarding@resend.dev>"
#
# Backend B — SMTP (Gmail, Fastmail, your own mail server, ...):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465                    # 465 = implicit TLS, 587 = STARTTLS
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-app-password      # Gmail: create an App Password
#
# The email is written in REPORT_LANGUAGE (English or German supported).

# --- Database driver ---
# Local/default: SQLite (no setup). For deployment, use Postgres (e.g. Supabase).
#
#   DB_DRIVER=sqlite                 SQLite (default)
#   DB_DRIVER=postgres               Postgres — requires DATABASE_URL below
#
# If DATABASE_URL is set and DB_DRIVER is unset, Postgres is selected automatically.
# DB_DRIVER=sqlite

# Where the SQLite database is stored (only used by the sqlite driver).
# DB_PATH=./data/reviews.db

# Postgres / Supabase connection string (only used by the postgres driver).
# Supabase: Project Settings -> Database -> Connection string -> "Session pooler"
# (or the direct connection). Append ?sslmode=require if your client needs it.
# DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
#
# TLS is enabled automatically for non-localhost hosts. Set to false to disable.
# DATABASE_SSL=true
# Max pooled connections (default 10).
# DATABASE_POOL_MAX=10

# --- Scheduled job ---
# The daily job (review sync + ratings snapshot + LLM report + email) can run
# either in-process via node-cron, or externally via GitHub Actions (free, no
# always-on server needed — see .github/workflows/daily.yml).
#
# Cron expression for the in-process scheduler (default 06:00 daily).
# SYNC_CRON=0 6 * * *
#
# Set to 1 to DISABLE the in-process cron — use this when an external scheduler
# (GitHub Actions) runs the job, so it doesn't run twice.
# DISABLE_CRON=0

# --- Dashboard login (optional) ---
# When DASHBOARD_PASSWORD is set, the web UI requires a single shared password
# (login page + signed session cookie). Leave unset for an open local dashboard.
# Always set this when deploying publicly (e.g. on Render).
# DASHBOARD_PASSWORD=choose-a-strong-passphrase
#
# Secret used to sign session cookies. Optional — if unset, a stable secret is
# derived from DASHBOARD_PASSWORD. Set an explicit random value in production so
# changing the password and signing key are independent.
# SESSION_SECRET=some-long-random-string

